# ── Build output ──────────────────────────────────────────────────────────────
/target
**/target

# ── Docker secrets — contain live credentials, never commit ──────────────────
secrets/*
!secrets/.gitkeep

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── TLS / PKI material ────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.csr
*.srl
*.p12
*.pfx
*.der

# ── Other credential patterns ─────────────────────────────────────────────────
*.secret
*_secret
*.token
credentials/

# ── Rust / Cargo ──────────────────────────────────────────────────────────────
Cargo.lock          # omit for libraries; keep for binaries — this repo has both,
                    # so leaving it uncommitted avoids pinning implant builds

# ── Database files ────────────────────────────────────────────────────────────
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── OS and editor noise ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs and runtime state ────────────────────────────────────────────────────
*.log
logs/
